# Docker Compose — copy to .env in repo root
BACKEND_PORT=8000
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_PORT=3307
DB_DATABASE=nurul_hikmah
DB_USERNAME=nurul_hikmah
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# Frontend dev (host): Vite proxies /api → localhost:8000
VITE_API_URL=/api

# Optional: full stack with nginx + Vite in Docker
# APP_PORT=8080
# VITE_PORT=5173

# Auto-run migrations on backend start (set false to skip)
RUN_MIGRATIONS=true
